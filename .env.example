# ── AI News Generator (root .env) ───────────────────────────────────────

# Required: Claude API key for news generation
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override model (default: claude-opus-4-7)
# CLAUDE_MODEL=claude-sonnet-4-20250514

# Optional: override max tokens (default: 16000)
# CLAUDE_MAX_TOKENS=16000

# Optional: enable strict URL validation (default: false)
# STRICT_URL_CHECK=true

# ── Web (copy to web/.env.local) ────────────────────────────────────────

# PostgreSQL — local: docker-compose up
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_marketer_daily

# Redis — local: docker-compose up
REDIS_URL=redis://localhost:6379

# Anthropic — Claude Sonnet 4.5 (drafts) + Haiku 4.5 (translation)
ANTHROPIC_API_KEY=sk-ant-...

# Supabase (auth only)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...

# Kimi — AI News tool
KIMI_API_KEY=sk-...

# ── Bot (copy to bot/.env) ───────────────────────────────────────────────

# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=110201543:AAHdqTcvCH1vGWJxfSeofSAs0K5PALDsaw

# Public HTTPS URL for Telegram Webhook delivery
# Local dev: ngrok http 3001 → copy the https URL
WEBHOOK_URL=https://your-ngrok-or-domain.com

BOT_PORT=3001

# Web dashboard base URL (used in Telegram message links)
WEB_BASE_URL=https://welike-integrate.vercel.app


DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_marketer_daily
