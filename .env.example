# ── AI News Generator (root .env) ───────────────────────────────────────

# Required: Claude API key for news generation
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override model (default: claude-opus-4-7)
# CLAUDE_MODEL=claude-sonnet-4-20250514

# Optional: override max tokens (default: 16000)
# CLAUDE_MAX_TOKENS=16000

# Optional: enable strict URL validation (default: false)
# STRICT_URL_CHECK=true

# ── Web (copy to web/.env.local) ────────────────────────────────────────

# PostgreSQL — local: docker-compose up
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_marketer_daily

# Redis — local: docker-compose up
REDIS_URL=redis://localhost:6379

# Anthropic — Claude Sonnet 4.5 (drafts) + Haiku 4.5 (translation)
ANTHROPIC_API_KEY=sk-ant-...

# Supabase (auth only)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...

# Kimi — AI News tool
KIMI_API_KEY=sk-...

# ── Bot (copy to bot/.env) ───────────────────────────────────────────────

# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=110201543:AAHdqTcvCH1vGWJxfSeofSAs0K5PALDsaw

# Public HTTPS URL for Telegram Webhook delivery
# Local dev: ngrok http 3001 → copy the https URL
WEBHOOK_URL=https://your-ngrok-or-domain.com

BOT_PORT=3001

# Web dashboard base URL (used in Telegram message links)
WEB_BASE_URL=https://welike-integrate.vercel.app


DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_marketer_daily

# ── Social Listening ───────────────────────────────────────────────────

# X / Twitter — pick one (X bearer is preferred; twitterapi.io is fallback).
# X_BEARER_TOKEN requires X API Basic tier ($200/mo) for /2/tweets/search/recent.
X_BEARER_TOKEN=
TWITTERAPI_KEY=

# Vercel Cron auth — required for /api/social-listening/cron/poll-alerts.
# Generate any random string; Vercel injects it as Bearer token automatically.
CRON_SECRET=

# Public web URL — used by Telegram CTAs and "deep links" back to
# /tools/social-listening. Same value as WEB_BASE_URL above is fine.
WEB_URL=https://welike-integrate.vercel.app

# Optional: bot @username (without @). Skipping it triggers a getMe call to
# resolve at runtime; set to avoid that round-trip. Example: WeLike_Alerts_bot
# TELEGRAM_BOT_USERNAME=

# Optional: route the sl_user / sl_alert / sl_pushed_tweet / sl_web_link /
# sl_task tables to a different Postgres than DATABASE_URL. If unset, falls
# back to DATABASE_URL — this is the recommended path so all WeLike data
# lives in one DB.
# SOCIAL_LISTENING_DATABASE_URL=
