# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Anthropic — used by KOL Pricer (and other AI features)
ANTHROPIC_API_KEY=sk-ant-...

# X/Twitter API bearer token — used by KOL Pricer to fetch user/tweet data
X_BEARER_TOKEN=AAAAAAAAA...

# Cloudflare Turnstile — used on login/register pages for bot protection
NEXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA

# Product Submissions (team review database)
# Get this from Supabase Dashboard → Settings → API → service_role key
# Required for the admin review page to read all submissions
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: Protect the admin submissions page with a Bearer token
# ADMIN_API_TOKEN=your-secret-token
