{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "fluid": true,
  "crons": [
    {
      "path": "/api/social-listening/cron/poll-alerts",
      "schedule": "0 0 * * *"
    }
  ],
  "functions": {
    "app/api/social-listening/analyze/route.ts": { "maxDuration": 300 },
    "app/api/social-listening/report/[taskId]/generate/route.ts": { "maxDuration": 300 },
    "app/api/social-listening/cron/poll-alerts/route.ts": { "maxDuration": 300 },
    "app/api/social-listening/alerts/[alertId]/run/route.ts": { "maxDuration": 60 },
    "app/api/social-listening/timeline/[taskId]/route.ts": { "maxDuration": 60 },
    "app/api/social-listening/chat/route.ts": { "maxDuration": 60 },
    "app/api/social-listening/generate-reply/route.ts": { "maxDuration": 60 }
  }
}
