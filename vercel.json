{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "installCommand": "npm ci --prefix web",
  "buildCommand": "npm run build --prefix web",
  "outputDirectory": "web/.next",
  "fluid": true,
  "crons": [
    {
      "path": "/api/social-listening/cron/poll-alerts",
      "schedule": "*/10 * * * *"
    }
  ],
  "functions": {
    "web/app/api/social-listening/analyze/route.ts": { "maxDuration": 300 },
    "web/app/api/social-listening/report/[taskId]/generate/route.ts": { "maxDuration": 300 },
    "web/app/api/social-listening/cron/poll-alerts/route.ts": { "maxDuration": 300 },
    "web/app/api/social-listening/alerts/[alertId]/run/route.ts": { "maxDuration": 60 },
    "web/app/api/social-listening/timeline/[taskId]/route.ts": { "maxDuration": 60 },
    "web/app/api/social-listening/chat/route.ts": { "maxDuration": 60 },
    "web/app/api/social-listening/generate-reply/route.ts": { "maxDuration": 60 }
  }
}
