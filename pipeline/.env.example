# Anthropic — required for draft generation
# Get key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Product Hunt Developer Token — required for Launch Radar
# IMPORTANT: this is the "Developer Token" (~64 chars), NOT a Client ID/Secret.
# Generate at https://www.producthunt.com/v2/oauth/applications → Application detail
# → "Create Token" with `public` scope.
PH_TOKEN=...

# Optional: override target date (default: today in America/Los_Angeles)
# TARGET_DATE=2026-05-01

# Optional: where to write drafts (default: content/drafts)
# DRAFT_DIR=content/drafts

# ─────────────────────────────────────────────────────────────────
# Removed 2026-04-25:
#   APIFY_TOKEN — was used for X scraping, but Apify free tier no longer
#   returns real tweets after 2025-2026 X anti-scraping changes. Replaced
#   by Substack RSS in pipeline/fetch/substack.py. See pipeline/README.md
#   FAQ for full reasoning.
# ─────────────────────────────────────────────────────────────────
