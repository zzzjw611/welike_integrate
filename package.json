{
  "name": "ai-product-gtm-co-pilot",
  "version": "1.0.0",
  "description": "AI-native GTM platform for AI products — multi-agent system powered by Claude",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/cli.js",
    "dev": "tsx src/cli.ts",
    "scout": "tsx src/cli.ts --agent scout",
    "strategist": "tsx src/cli.ts --agent strategist",
    "content": "tsx src/cli.ts --agent content",
    "pipeline": "tsx src/cli.ts --pipeline"
  },
  "keywords": [
    "gtm",
    "ai-agents",
    "marketing",
    "claude"
  ],
  "author": "JE Labs",
  "license": "ISC",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "dotenv": "^17.3.1",
    "ora": "^9.3.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
